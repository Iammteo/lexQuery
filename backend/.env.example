# ── App ──────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=LexQuery
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# ── API ──────────────────────────────────────────────────────────
API_V1_PREFIX=/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=lexquery
POSTGRES_PASSWORD=lexquery_dev
POSTGRES_DB=lexquery
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async DSN (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://lexquery:lexquery_dev@localhost:5432/lexquery
# Sync DSN (used by Alembic)
DATABASE_URL_SYNC=postgresql://lexquery:lexquery_dev@localhost:5432/lexquery

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Weaviate ─────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080

# ── Auth / JWT ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
# Access token expires in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=480
# API key hash pepper (change in production)
API_KEY_PEPPER=change-this-pepper-in-production

# ── AI providers ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# ── AWS S3 ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
S3_BUCKET_NAME=lexquery-documents-dev
# Leave blank to use real AWS; set to http://localhost:9000 for MinIO
S3_ENDPOINT_URL=

# ── Ingestion ────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=128
EMBEDDING_MODEL=text-embedding-3-large

# ── Retrieval ────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
LLM_MODEL=claude-sonnet-4-20250514
QUERY_CACHE_TTL_SECONDS=900
